{
  "dependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "jwt-decode": "^4.0.0",
    "tailwindcss": "^4.3.1"
  },
  "scripts": {
    "dev:css": "tailwindcss -i ./src/input.css -o public/css/style.css --watch",
    "dev:js": "esbuild src/js/header.js --bundle --outfile=public/js/header.js --watch",
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:js\"",
    "build:css": "tailwindcss -i ./src/input.css -o public/css/style.css --minify",
    "build:js": "esbuild src/js/header.js --bundle --minify --outfile=public/js/header.js",
    "build": "npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "daisyui": "^5.6.5",
    "esbuild": "^0.28.1"
  }
}